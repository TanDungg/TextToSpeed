{
  "name": "my-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "npm run dev",
    "dev": "vite",
    "build": "rmdir /s /q dist 2>nul & vite build --outDir dist && copy web.config dist\\",
    "build:electron:web": "rmdir /s /q dist-electron 2>nul & vite build --outDir dist-electron",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "dist:win": "npm run build:electron:web && electron-builder --win nsis --config electron-builder.json",
    "clean:web": "rmdir /s /q dist 2>nul",
    "clean:electron:web": "rmdir /s /q dist-electron 2>nul",
    "clean:release": "rmdir /s /q release 2>nul",
    "clean:all": "rmdir /s /q dist 2>nul & rmdir /s /q dist-electron 2>nul & rmdir /s /q release 2>nul"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
    "@capacitor/android": "^7.4.0",
    "@capacitor/cli": "^7.4.0",
    "@capacitor/core": "^7.4.0",
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@giphy/js-fetch-api": "^5.6.0",
    "@giphy/react-components": "^10.0.1",
    "@microsoft/signalr": "^8.0.7",
    "@reduxjs/toolkit": "^2.6.1",
    "@tanstack/react-query": "^5.96.2",
    "antd": "^5.24.8",
    "axios": "^1.8.4",
    "emoji-mart": "^5.6.0",
    "firebase": "^11.8.1",
    "history": "^5.3.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.1",
    "lucide-react": "^0.508.0",
    "numeral": "^2.0.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0",
    "react-photo-view": "^1.2.7",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.4.0",
    "react-use": "^17.6.0",
    "redux": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "postcss": "^8.4.31",
    "sass-embedded": "^1.89.0",
    "tailwindcss": "^3.4.1",
    "vite": "^6.2.0",
    "wait-on": "^9.0.5"
  }
}
